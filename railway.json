{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "distro": "ubuntu22",
      "image": "railwayapp/nixpacks:nodejs-20",
      "aptPackages": []
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "runCommand": "npm start",
    "healthcheckPath": "/health",
    "healthcheckPort": 8080
  }
}
